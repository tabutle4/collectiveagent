{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/agent/layout,_N_T_/agent/form-responses/layout,_N_T_/agent/form-responses/page,_N_T_/agent/form-responses"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/agent/form-responses/__PAGE__",
    "/agent/form-responses",
    "/agent",
    "/_index",
    "/_head"
  ]
}